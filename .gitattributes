# Auto-detect text files and normalize line endings
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Config files (LF for cross-platform compatibility)
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Shell scripts (LF required)
*.sh text eol=lf

# Windows-specific (keep CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.db binary
